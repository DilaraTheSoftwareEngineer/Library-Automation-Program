<dx:ThemedWindow
    x:Class="LibraryAutomationn.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
    xmlns:local="clr-namespace:LibraryAutomationn"
    WindowStyle="None" AllowsTransparency="True" Background="Transparent"
    Title="Library System" Height="800" Width="1200" WindowStartupLocation="CenterScreen">

    <dx:ThemedWindow.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
        <local:FavoriteIconConverter x:Key="FavoriteIconConverter"/>
        
        
        <ControlTemplate x:Key="BookCardTemplate">
            <Border Width="240" Height="360" Margin="12" CornerRadius="20" Background="#1AFFFFFF" BorderBrush="#25FFFFFF" BorderThickness="1.5" MouseLeftButtonUp="CardBorder_MouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="0" Color="#FF00E5FF" Opacity="0" ShadowDepth="0"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#FF00E5FF" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="20" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.Opacity)" To="0.7" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#25FFFFFF" Duration="0:0:0.3"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(Border.Effect).(DropShadowEffect.BlurRadius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="15">
                    
                    <StackPanel>
                        <Grid>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#000000" Offset="1"/>
                                    <GradientStop Color="#16003B" Offset="0.3"/>
                                    <GradientStop Color="#001C30" Offset="0.7"/>
                                    <GradientStop Color="#2D033B" Offset="0"/>
                                </LinearGradientBrush>
                            </Grid.Background>

                            <Border Height="180" CornerRadius="15" Background="#20000000" ClipToBounds="True">
                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                            </Border>
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Favorite_Click" CommandParameter="{Binding}">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style>
                                </Button.Resources>
                                <TextBlock Text="{Binding IsFavorite, Converter={StaticResource FavoriteIconConverter}}" FontSize="25" Margin="5,2" Background="Transparent" Foreground="Red" />
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,15,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Author.Name}" Foreground="#88FFFFFF" FontSize="14" MouseLeftButtonUp="AuthorDetail_Click"/>
                        <Border Background="#2200E5FF" HorizontalAlignment="Left" CornerRadius="5" Padding="5,2" Margin="0,5" />
                        <Border Background="#2200E5FF" HorizontalAlignment="Left" CornerRadius="5" Padding="5,2" Margin="0,5">
                            <TextBlock Text="{Binding Genre.Name, TargetNullValue='Türsüz'}" Foreground="Cyan" FontSize="11" FontWeight="SemiBold" Cursor="Hand"  MouseLeftButtonUp="GenreCard_Click" />
                        </Border>
                        <Border Background="{Binding IsBorrowed, Converter={StaticResource StatusColorConverter}}" HorizontalAlignment="Left" CornerRadius="8" Padding="10,4" Margin="0,10,0,0">
                            <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="RAFTA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBorrowed}" Value="True">
                                                <Setter Property="Text" Value="ÖDÜNÇTE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </ControlTemplate>
    </dx:ThemedWindow.Resources>

    <Grid>
        <Border CornerRadius="20" Background="#0F051D"/>

        <Border Margin="15" CornerRadius="25" Background="#12FFFFFF" BorderBrush="#25FFFFFF" BorderThickness="1.5">
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2D033B" Offset="0"/>
                        <GradientStop Color="#16003B" Offset="0.3"/>
                        <GradientStop Color="#001C30" Offset="0.7"/>
                        <GradientStop Color="#000000" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#15000000" CornerRadius="25,0,0,25" BorderBrush="#15FFFFFF" BorderThickness="0,0,1,0">
                    <StackPanel Margin="20,50">
                        <TextBlock Text="Library AI" Foreground="White" FontSize="28" FontWeight="ExtraBold" Margin="10,0,0,50"/>
                        <Button Content="Dashboard" Style="{StaticResource NavButtonStyle}" Click="Menu_Click" Tag="Dash"/>
                        <Button Content="Kitaplarım" Style="{StaticResource NavButtonStyle}" Margin="0,10,0,0" Click="Menu_Click" Tag="MyBooks"/>
                        <Button Content="Keşfet" Style="{StaticResource NavButtonStyle}" Margin="0,10,0,0" Click="Menu_Click" Tag="Discovery"/>
                        <Button Content="Başarılarım" Style="{StaticResource NavButtonStyle}" Click="Menu_Click" Tag="Badges"/><Border x:Name="AdminSeparator" Height="1" Background="#22FFFFFF" Margin="0,20" Visibility="Collapsed"/>
                        <Button x:Name="btnAdminPanel" Content="Admin Panel" Visibility="Collapsed" Foreground="Orange" Style="{StaticResource NavButtonStyle}" Click="Menu_Click" Tag="Admin" Margin="0,20,0,0"/>
                        <Button Content="Çıkış Yap" Foreground="Red" Style="{StaticResource NavButtonStyle}" Margin="0,50,0,0" Click="Logout_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Column="1" Margin="40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock x:Name="txtWelcome" Text="Welcome to the System" Foreground="Wheat" FontSize="34" FontWeight="Bold"/>
                    </StackPanel>

                    <Border Grid.Row="1" Width="450" HorizontalAlignment="Left" Height="45" Margin="0,10,0,20" CornerRadius="22" Background="#1AFFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1.2">
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" Margin="20,0" TextChanged="SearchBox_TextChanged"/>
                    </Border>

                    <Grid Grid.Row="2">
                        <ScrollViewer x:Name="DashPanel" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="10">
                                <TextBlock Text="Kategoriler" Foreground="Wheat" FontSize="22" FontWeight="Bold" Margin="10,0,0,15"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,30">
                                    <ItemsControl x:Name="GenresList">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Name}" Click="GenreCard_Click" Margin="0,0,10,0" Padding="20,10" Background="#1AFFFFFF" Foreground="Cyan" Cursor="Hand">
                                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="15"/></Style></Button.Resources>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Text="Öne Çıkan Yazarlar" Foreground="Wheat" FontSize="22" FontWeight="Bold" Margin="10,0,0,15"/>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,30">
                                    <ItemsControl x:Name="AuthorsList">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,20,0" Cursor="Hand" MouseLeftButtonUp="AuthorCard_Click" Tag="{Binding Name}">
                                                    <Border Width="80" Height="80" CornerRadius="40" BorderBrush="#FF00E5FF" BorderThickness="2" ClipToBounds="True">
                                                        <Image Source="https://cdn-icons-png.flaticon.com/512/1995/1995531.png" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="12"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Text="Tüm Kitaplar" Foreground="Wheat" FontSize="22" FontWeight="Bold" Margin="10,0,0,15"/>
                                <ItemsControl x:Name="BooksList">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate><ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/></DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <ScrollViewer x:Name="MyBooksPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="10">
                                <TextBlock Text="Şu An Ödünç Aldıklarım" Foreground="Orange" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                                <ItemsControl x:Name="CurrentBorrowedList" Margin="0,0,0,30">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Favorilerim" Foreground="Red" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                                <ItemsControl x:Name="FavoritesList" Margin="0,0,0,30">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Geçmiş Okuduklarım" Foreground="Gray" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                                <ItemsControl x:Name="PastBooksList">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate><ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                        <Border x:Name="BookDetailPanel" Visibility="Collapsed" CornerRadius="20" Background="#22000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid Margin="30">
                                <StackPanel>
                                    <Button Content="← Geri Dön" Foreground="Cyan" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Click="BackToDash_Click"/>
                                    <Grid Margin="0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Height="280" CornerRadius="15" Background="#20000000" ClipToBounds="True">
                                            <Image x:Name="imgDetay" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="30,0">
                                            <TextBlock x:Name="txtDetayBaslik" FontSize="36" FontWeight="Bold" Foreground="White"/>
                                            <TextBlock x:Name="txtDetayYazar" FontSize="20" Foreground="Cyan" Cursor="Hand" MouseLeftButtonUp="AuthorDetail_Click" Margin="0,5"/>
                                            <TextBlock x:Name="txtDetayTur" FontSize="16" Foreground="Cyan" Margin="0,5" FontStyle="Italic" Cursor="Hand" MouseLeftButtonUp="GenreFilter_Click"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                                <Border x:Name="brdStatus" CornerRadius="5" Padding="8,3" Background="Green" Margin="0,0,10,0">
                                                    <TextBlock x:Name="txtStatus" Text="RAFTA" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                                </Border>
                                                <TextBlock x:Name="txtDetayRaf" FontSize="16" Foreground="#AAFFFFFF" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="AI Analizi" Foreground="Yellow" Margin="0,20,0,5" FontWeight="Bold"/>
                                            <Border Background="#15FFFFFF" Padding="15" CornerRadius="10">
                                                <TextBlock x:Name="txtDetayAI" Foreground="#EEEEEE" TextWrapping="Wrap" FontSize="14"/>
                                            </Border>
                                            <Button x:Name="btnBorrowAction" Content="Ödünç Al" Height="45" Width="200" HorizontalAlignment="Left" Margin="0,25" Background="#FF00E5FF" Foreground="#0F051D" FontWeight="Bold" Click="Borrow_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                       

                        <Border x:Name="AuthorDetailPanel" Visibility="Collapsed" CornerRadius="20" Background="#22000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid Margin="30">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Button Content="← Kitaba Dön" Foreground="Orange" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Click="BackToBook_Click"/>
                                        <TextBlock x:Name="txtAuthorName" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/>
                                        <TextBlock Text="Biyografi" Foreground="Gray" FontSize="16" Margin="0,10"/>
                                        <Border Background="#10FFFFFF" Padding="15" CornerRadius="10" Margin="0,0,0,20">
                                            <TextBlock x:Name="txtAuthorBioDetail" Foreground="White" TextWrapping="Wrap" FontSize="16"/>
                                        </Border>
                                        <TextBlock Text="Yazarın Diğer Eserleri" Foreground="Gray" FontSize="16" Margin="0,10"/>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="AuthorBooksList">
                                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate><DataTemplate><ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/></DataTemplate></ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <Border x:Name="BadgesPanel" Visibility="Collapsed" CornerRadius="20" Background="#0F051D" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Button Content="← Geri Dön" Click="BackToDash_Click" HorizontalAlignment="Left" Foreground="Cyan" Background="Transparent" BorderThickness="0"/>

                                <StackPanel Grid.Row="1" Margin="0,20" HorizontalAlignment="Center">
                                    <Border Width="100" Height="100" CornerRadius="50" BorderBrush="Gold" BorderThickness="3">
                                        <Image Source="https://cdn-icons-png.flaticon.com/512/3135/3135715.png"/>
                                    </Border>
                                    <TextBlock x:Name="txtProfileName" Text="Hoşgeldin, Okur!" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,10"/>
                                    <TextBlock x:Name="txtReadingStats" Text="Toplam 12 Kitap Okundu" Foreground="Gray" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,20">
                                    <WrapPanel HorizontalAlignment="Center">
                                        <StackPanel Margin="15" Width="120">
                                            <Border x:Name="badgeBookWorm" Width="80" Height="80" CornerRadius="40" Background="#1AFFFFFF" Opacity="0.3">
                                                <Image Source="https://cdn-icons-png.flaticon.com/512/1903/1903162.png" Margin="15"/>
                                            </Border>
                                            <TextBlock Text="Kitap Kurdu" Foreground="White" HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBlock Text="2 Kitap Oku" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Margin="15" Width="120">
                                            <Border x:Name="badgeSpeedReader" Width="80" Height="80" CornerRadius="40" Background="#1AFFFFFF" Opacity="0.3">
                                                <Image Source="https://cdn-icons-png.flaticon.com/512/1039/1039328.png" Margin="15"/>
                                            </Border>
                                            <TextBlock Text="Hız Ustası" Foreground="White" HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBlock Text="3 Günde Bitir" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Margin="15" Width="120">
                                            <Border x:Name="badgeNightOwl" Width="80" Height="80" CornerRadius="40" Background="#1AFFFFFF" Opacity="0.3">
                                                <Image Source="https://cdn-icons-png.flaticon.com/512/2043/2043213.png" Margin="15"/>
                                            </Border>
                                            <TextBlock Text="Gece Kuşu" Foreground="White" HorizontalAlignment="Center" Margin="0,5"/>
                                            <TextBlock Text="Gece Kitap Al" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </WrapPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                        <StackPanel>
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                             </Grid>

                            
                        </StackPanel>
                        <Border x:Name="DiscoveryPanel" Visibility="Collapsed" CornerRadius="20" Background="#0F051D" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="30">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Button Content="← Geri Dön" Click="BackToDash_Click" HorizontalAlignment="Left" Foreground="Cyan" Background="Transparent" BorderThickness="0"/>

                                    <TextBlock Grid.Row="1" Text="Günün Seçimi" Foreground="Gold" FontSize="26" FontWeight="Bold" Margin="0,20,0,10"/>

                                    <Border Grid.Row="2" Height="200" CornerRadius="20" Background="#1AFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" Margin="0,0,0,30">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Margin="15" CornerRadius="10" ClipToBounds="True">
                                                <Image x:Name="imgDiscoveryToday" Stretch="UniformToFill" Source="https://via.placeholder.com/150"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                                <TextBlock x:Name="txtDiscoveryTitle" Text="Kitap Adı" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock x:Name="txtDiscoveryAuthor" Text="Yazar Adı" FontSize="16" Foreground="Cyan"/>
                                                <TextBlock x:Name="txtDiscoveryQuote" Text="&quot;Bu kitap ruhunuzu dinlendirecek...&quot;" FontStyle="Italic" Foreground="#AAA" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="Hemen İncele" Click="DiscoveryReview_Click" Margin="20" Padding="15,5" Background="Gold" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="10"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="3">
                                        <TextBlock Text="Senin İçin AI Önerileri" Foreground="Wheat" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl x:Name="DiscoverySuggestionsList">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </Border>
                        <Border x:Name="AdminPanel" Visibility="Collapsed" CornerRadius="20" Background="#0F051D">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    

                                    <Border Grid.Column="0" Margin="5" Background="#22FFFFFF" CornerRadius="15" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="📚 Toplam Kitap" Foreground="#AAA" FontSize="12"/>
                                            <TextBlock x:Name="txtStatTotalBooks" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Margin="5" Background="#22FF4444" CornerRadius="15" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="📖 Ödünçte" Foreground="#FF8888" FontSize="12"/>
                                            <TextBlock x:Name="txtStatBorrowedBooks" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Margin="5" Background="#2244FF44" CornerRadius="15" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="👥 Kayıtlı Üye" Foreground="#88FF88" FontSize="12"/>
                                            <TextBlock x:Name="txtStatTotalUsers" Text="0" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="3" Margin="5" Background="#224444FF" CornerRadius="15" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="🌟 Popüler Tür" Foreground="#8888FF" FontSize="12"/>
                                            <TextBlock x:Name="txtStatPopularGenre" Text="-" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                                    <TabItem Header="Kitap &amp; Yazar Yönetimi">
                                        <Grid Margin="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="350"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="10">
                                                <TextBlock Text="📚Mevcut Kitaplar" Foreground="Orange" FontSize="20" Margin="0,0,0,10" FontWeight="Bold"/>
                                                <DataGrid x:Name="dgAdminBooks" Height="380" Background="#1AFFFFFF" Foreground="Black" AutoGenerateColumns="False" BorderThickness="0">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Başlık" Binding="{Binding Title}" Width="*"/>
                                                        <DataGridTextColumn Header="Yazar" Binding="{Binding Author.Name}" Width="*"/>
                                                        <DataGridTextColumn Header="Durum" Binding="{Binding IsBorrowed}" Width="100"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <Button Content="Seçili Kitabı Sil" Background="#EE4444" Foreground="White" Margin="0,10" Click="AdminDeleteBook_Click" Cursor="Hand"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="#1AFFFFFF" CornerRadius="15" Padding="10" Margin="10,0,0,0">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <TextBlock Text="➕KİTAP EKLEME FORMU" Foreground="Gold" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

                                                        <TextBlock Text="Kitap Adı:" Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                                                        <TextBox x:Name="txtAddTitle" Padding="8" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>

                                                        <TextBlock Text="Yazar Seçimi:" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                                        <ComboBox x:Name="cbAddAuthor" DisplayMemberPath="Name" Height="35"/>

                                                        <TextBlock Text="Tür / Kategori:" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                                        <ComboBox x:Name="cbAddGenre" DisplayMemberPath="Name" Height="35"/>

                                                        <TextBlock Text="Raf Konumu (Örn: A-12):" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                                        <TextBox x:Name="txtAddShelf" Padding="8" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>

                                                        <TextBlock Text="Kapak Resim Linki (URL):" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                                        <TextBox x:Name="txtAddImageUrl" Padding="8" Background="#22FFFFFF" Foreground="White" BorderThickness="0"/>

                                                        <Button Content="SİSTEME KAYDET" Background="Green" Foreground="White" FontWeight="Bold" Height="40" Margin="0,20,0,0" Click="AdminAddBook_Click">
                                                            <Button.Resources>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="CornerRadius" Value="10"/>
                                                                </Style>
                                                            </Button.Resources>
                                                        </Button>

                                                        <StackPanel Margin="0,25,0,0">
                                                            <Separator Background="#33FFFFFF" Margin="0,0,0,15"/>
                                                            <TextBlock Text="✍️YAZAR EKLEME FORMU" Foreground="Cyan" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>

                                                            <TextBlock Text="Yazar Adı Soyadı:" Foreground="Gray" FontSize="11"/>
                                                            <TextBox x:Name="txtQuickAuthorName" Padding="8" Background="#22FFFFFF" Foreground="White" BorderThickness="0" Margin="0,5"/>

                                                            <TextBlock Text="Yazar Biyografisi:" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>
                                                            <TextBox x:Name="txtAuthorBio" Padding="8" Background="#22FFFFFF" Foreground="White" BorderThickness="0" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5"/>

                                                            <Button Content="YAZARI KAYDET" Background="Blue" Foreground="White" FontWeight="Bold" Height="35" Margin="0,10" Click="AdminAddAuthor_Click">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="8"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </Grid>
                                    </TabItem>

                                    <TabItem Header="Kullanıcı &amp; Ödünç Takibi">
                                        <Grid Margin="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="10">
                                                <TextBlock Text="Ödünç Hareketleri" Foreground="Cyan" FontSize="20" Margin="0,0,0,10" FontWeight="Bold"/>
                                                <DataGrid x:Name="dgBorrowLogs" Height="380" Background="#1AFFFFFF" Foreground="Black" AutoGenerateColumns="False" BorderThickness="0">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Kitap" Binding="{Binding Title}" Width="*"/>
                                                        <DataGridTextColumn Header="Alan" Binding="{Binding BorrowedBy}" Width="*"/>
                                                        <DataGridTextColumn Header="Tarih" Binding="{Binding BorrowDate, StringFormat=d}" Width="Auto"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="10">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <TextBlock Text="Kullanıcı Yönetimi" Foreground="Red" FontSize="20" Margin="0,0,0,10" FontWeight="Bold"/>
                                                        <DataGrid x:Name="dgUsers" Height="380" Background="#1AFFFFFF" Foreground="Black" AutoGenerateColumns="False" BorderThickness="0">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Kullanıcı Adı" Binding="{Binding Username}" Width="*"/>
                                                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="100"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                        <Button Content="Seçili Kullanıcıyı BANLA" Background="Black" Foreground="White" Margin="0,10" Click="AdminBanUser_Click" FontWeight="Bold" Cursor="Hand"/>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Grid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                        <Border x:Name="GenreDetailPanel" Visibility="Collapsed" CornerRadius="20" Background="#0F051D" BorderBrush="#33FFFFFF" BorderThickness="1">
                            <Grid Margin="30">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <Button Content="← Geri Dön" Foreground="Cyan" Background="Transparent" BorderThickness="0" HorizontalAlignment="Left" Click="BackToDash_Click"/>
                                    <TextBlock x:Name="txtGenreDetailName" FontSize="42" FontWeight="Bold" Foreground="White" Margin="0,20,0,10"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="GenreBooksList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ContentControl Template="{StaticResource BookCardTemplate}" Content="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
            
        </Border>
    </Grid>
</dx:ThemedWindow>